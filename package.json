  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rakibmridha/bright-corner-api.git"
  },
  "keywords": [],
  "main": "dist/index.js",
  "scripts": {
    "start": "node --require ./tsconfig-paths-bootstrap.js --env-file=.env dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
